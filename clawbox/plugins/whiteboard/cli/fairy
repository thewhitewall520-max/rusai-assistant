#!/bin/bash
# ============================================================
# 🧩 fairy — 白板 CLI 工具
# 智能协作白板插件 Lite 版 v1.0.0
# 依赖: bash + python3 (macOS 自带)
# ============================================================
set -e

# 定位脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FAIRY_DIR="${FAIRY_DIR:-$HOME/.openclaw/workspace/.fairy}"

# 尝试加载 lib/state.sh（支持多种安装路径）
_load_lib() {
  local search_paths=(
    "$SCRIPT_DIR/../lib/state.sh"
    "$SCRIPT_DIR/lib/state.sh"
    "$HOME/.local/lib/fairy/state.sh"
    "/usr/local/lib/fairy/state.sh"
  )
  for path in "${search_paths[@]}"; do
    if [ -f "$path" ]; then
      source "$path"
      return 0
    fi
  done
  echo "❌ 无法加载 state.sh 库。请重新运行 install.sh"
  exit 1
}

_load_lib

# ---------- 确保 .fairy 目录存在 ----------
_ensure_state() {
  ensure_fairy_dir
  if [ ! -f "$STATE_FILE" ]; then
    echo "⚠️  state.json 不存在，正在初始化..."
    local timestamp
    timestamp=$(date +"%Y-%m-%dT%H:%M:%S+08:00")
    cat > "$STATE_FILE" << EOF
{
  "currentProject": "my-project",
  "projects": {
    "my-project": {
      "name": "我的项目",
      "phase": "需求",
      "chainBroken": false,
      "agents": {},
      "awaitingDecision": [],
      "createdAt": "$timestamp",
      "updatedAt": "$timestamp"
    }
  }
}
EOF
    echo "✅ state.json 已初始化"
  fi
}

# ---------- 命令: status ----------
_cmd_status() {
  _ensure_state
  local project_arg=""
  if [ -n "$1" ]; then
    project_arg="$1"
  fi
  check_chain "$project_arg"
}

# ---------- 命令: log ----------
_cmd_log() {
  _ensure_state
  local message="$*"
  if [ -z "$message" ]; then
    echo "❌ 用法: fairy log <消息内容>"
    echo "   例: fairy log 纳兹 完成需求分析"
    exit 1
  fi
  append_changelog "$message"
}

# ---------- 命令: lesson ----------
_cmd_lesson() {
  _ensure_state
  local topic="$1"

  if [ -z "$topic" ]; then
    echo "❌ 用法: fairy lesson <主题> <详细说明>"
    echo "   例: fairy lesson API超时 \"增加超时时间阈值\""
    exit 1
  fi

  shift
  local detail="$*"

  if [ -z "$detail" ]; then
    echo "❌ 用法: fairy lesson <主题> <详细说明>"
    echo "   例: fairy lesson API超时 \"增加超时时间阈值\""
    exit 1
  fi
  append_lesson "$topic" "$detail"
}

# ---------- 命令: chain-check ----------
_cmd_chain_check() {
  _ensure_state
  local project_arg=""
  if [ -n "$1" ]; then
    project_arg="$1"
  fi

  check_chain "$project_arg"

  # 检查是否真的中断了
  local state_content
  state_content=$(read_state "$project_arg")
  local chain_broken
  chain_broken=$(echo "$state_content" | python3 -c "import json,sys; d=json.load(sys.stdin); p=d.get('projects',{}).get(d.get('currentProject',''),{}); print(str(p.get('chainBroken',False)).lower())" 2>/dev/null || echo "false")

  if [ "$chain_broken" = "true" ]; then
    echo ""
    echo "⚠️  链式中断！请修复后再继续下一阶段。"
    echo "   使用 'fairy update-agent <name> fixed' 确认修复"
    exit 1
  fi

  echo ""
  echo "✅ 门禁通过，可以继续下一阶段。"
}

# ---------- 命令: update-agent ----------
_cmd_update_agent() {
  _ensure_state
  local agent_name="$1"
  local agent_status="$2"

  if [ -z "$agent_name" ] || [ -z "$agent_status" ]; then
    echo "❌ 用法: fairy update-agent <Agent名> <状态> [任务描述]"
    echo "   例: fairy update-agent natsu running 白板插件开发"
    echo "   状态: done | running | idle | failed | fixed"
    exit 1
  fi

  shift 2
  local agent_task="$*"

  # 验证状态值
  case "$agent_status" in
    done|running|idle|failed|fixed) ;;
    *)
      echo "❌ 无效状态: '$agent_status'"
      echo "   有效状态: done | running | idle | failed | fixed"
      exit 1
      ;;
  esac

  # 读取当前 state 获取当前项目名
  local current_state
  current_state=$(read_state)
  local current_project
  current_project=$(echo "$current_state" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('currentProject','my-project'))" 2>/dev/null || echo "my-project")

  # 构建 agents 更新 JSON
  python3 -c "
import json, sys, os

state_file = '$STATE_FILE'
agent_name = '$agent_name'
agent_status = '$agent_status'
agent_task = '''$agent_task'''
project = '$current_project'

with open(state_file) as f:
    state = json.load(f)

if project not in state.get('projects', {}):
    print(f'❌ 项目 \"{project}\" 不存在')
    sys.exit(1)

state['projects'][project]['agents'][agent_name] = {
    'status': agent_status,
    'task': agent_task
}

# If agent failed, set chainBroken; if fixed, clear it
if agent_status == 'failed':
    state['projects'][project]['chainBroken'] = True
if agent_status == 'fixed':
    state['projects'][project]['chainBroken'] = False

state['updatedAt'] = __import__('datetime').datetime.now().strftime('%Y-%m-%dT%H:%M:%S+08:00')

with open(state_file, 'w') as f:
    json.dump(state, f, indent=2, ensure_ascii=False)

print(f'✅ Agent \"{agent_name}\" 状态已更新为: {agent_status}')
" || {
    echo "❌ 更新 agent 状态失败"
    exit 1
  }
}

# ---------- 命令: help ----------
_cmd_help() {
  cat << 'EOF'
🧩 fairy — 智能协作白板 CLI 工具 v1.0.0

用法:
  fairy status [project]             — 显示当前项目/Agent 状态
  fairy log <message>                — 追加变更日志
  fairy lesson <topic> <detail>      — 添加经验记录
  fairy chain-check [project]        — 检查阶段门禁状态
  fairy update-agent <name> <status> [task] — 更新 Agent 状态
  fairy help                         — 显示此帮助

状态值:
  done       — 完成
  running    — 执行中
  idle       — 空闲
  failed     — 失败（会设置 chainBroken）
  fixed      — 已修复（清除 chainBroken）

环境变量:
  FAIRY_DIR  — 指定 .fairy 目录位置（默认: ~/.openclaw/workspace/.fairy）

示例:
  fairy status
  fairy log "纳兹 完成需求分析"
  fairy lesson API超时 "增加超时时间阈值"
  fairy chain-check
  fairy update-agent natsu running 白板插件开发
  fairy update-agent natsu done
EOF
}

# ============================================================
# 主路由
# ============================================================
_cmd="${1:-help}"
shift 2>/dev/null || true

case "$_cmd" in
  status)
    _cmd_status "$@"
    ;;
  log)
    _cmd_log "$@"
    ;;
  lesson)
    _cmd_lesson "$@"
    ;;
  chain-check)
    _cmd_chain_check "$@"
    ;;
  update-agent)
    _cmd_update_agent "$@"
    ;;
  help|--help|-h)
    _cmd_help
    ;;
  *)
    echo "❌ 未知命令: $_cmd"
    echo "   使用 'fairy help' 查看可用命令"
    exit 1
    ;;
esac
