generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URL 定義在 prisma.config.ts
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?  @unique
  name      String?
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  histories History[]
}

model History {
  id        String   @id @default(cuid())
  userId    String
  mode      String
  input     String
  output    String
  tone      String?
  target    String?
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Provider {
  sqlite
  postgresql
}
