// 数据库模型定义

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  name              String?
  avatar            String?
  preferredLanguage String    @default("zh") @map("preferred_language")
  subscriptionTier  String    @default("free") @map("subscription_tier")
  subscriptionEnd   DateTime? @map("subscription_end")
  
  // 使用统计
  totalWordsUsed    Int       @default(0) @map("total_words_used")
  aiRequestsCount   Int       @default(0) @map("ai_requests_count")
  
  // 关系
  documents         Document[]
  templates         Template[]
  apiKeys           ApiKey[]
  
  // 时间戳
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  
  @@map("users")
}

// 文档模型
model Document {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String
  content     String   @db.Text
  type        DocumentType
  language    String   @default("zh")
  status      DocumentStatus @default(draft)
  
  // 元数据
  wordCount   Int      @default(0) @map("word_count")
  charCount   Int      @default(0) @map("char_count")
  
  // AI 生成信息
  aiGenerated Boolean  @default(false) @map("ai_generated")
  aiModel     String?  @map("ai_model")
  
  // 关系
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions    DocumentVersion[]
  
  // 时间戳
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("documents")
}

// 文档版本
model DocumentVersion {
  id          String   @id @default(uuid())
  documentId  String   @map("document_id")
  content     String   @db.Text
  wordCount   Int      @default(0) @map("word_count")
  
  // 关系
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  // 时间戳
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([documentId])
  @@map("document_versions")
}

// 模板模型
model Template {
  id          String   @id @default(uuid())
  name        String
  category    TemplateCategory
  content     String   @db.Text
  language    String   @default("zh")
  description String?
  
  // 系统模板或用户自定义
  isSystem    Boolean  @default(false) @map("is_system")
  createdBy   String?  @map("created_by")
  
  // 使用统计
  usageCount  Int      @default(0) @map("usage_count")
  
  // 关系
  creator     User?    @relation(fields: [createdBy], references: [id])
  
  // 时间戳
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@index([category])
  @@index([language])
  @@map("templates")
}

// API Key 模型 (Enterprise)
model ApiKey {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  keyHash     String   @map("key_hash")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean  @default(true) @map("is_active")
  
  // 关系
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 时间戳
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([userId])
  @@map("api_keys")
}

// 翻译记录
model Translation {
  id            String   @id @default(uuid())
  sourceText    String   @db.Text @map("source_text")
  translatedText String  @db.Text @map("translated_text")
  sourceLang    String   @map("source_lang")
  targetLang    String   @map("target_lang")
  
  // 使用的翻译引擎
  engine        String   @default("openai")
  
  // 用户 (可选，匿名翻译)
  userId        String?  @map("user_id")
  
  // 时间戳
  createdAt     DateTime @default(now()) @map("created_at")
  
  @@index([userId])
  @@map("translations")
}

// 枚举类型
enum DocumentType {
  email
  essay
  translation
  general
  code
}

enum DocumentStatus {
  draft
  published
  archived
}

enum TemplateCategory {
  email
  essay
  resume
  report
  letter
  other
}
